  "npcs": [
    {
      "id": "the-helpful-innkeeper",
      "name": "Edrik Bakaris",
      "tag": "Noble · Vogler",
      "desc": "Edrik Bakaris \"the Younger\" shares the same name as his father, his father's father, and so on for generations. Bakaris places inordinate value on his good looks, fashionable clothes, and athleticism, but he's known more for his arrogance, pettiness, and short temper. He cares nothing for his family name, but he defers to his father—partly from unbroken childhood habit, and partly because all his privilege depends on his father's wealth. He loathes being called \"the Younger,\" a diminutive his father encourages.",
      "status": "Alive",
      "pageId": "",
      "img": "https://raw.githubusercontent.com/egregiemundi-bot/tangerine-unicorn-9d27ef/main/uploads/npcs/npc-the-helpful-innkeeper-1784262134454.jpg?v=1784262135736",
      "major": true,
      "location": "Kalaman",
      "vibeSong": {
        "title": "I'm Not Crying - Flight of the Conchords",
        "url": "https://open.spotify.com/track/2q7G9sbAUjju4iTvdBATpM?autoplay_ok=1"
      }
    },
    {
      "id": "new-npc-2",
      "name": "Ispin Greenshield",
      "tag": "Adventurer · Vogler",
      "desc": "Before retiring to the village of Vogler, Ispin Greenshield traveled across Ansalon as a teacher, trader, and adventurer. Along the way, he forged friendships with each of the characters. Each character knows the following information about him:\n- Ispin was a good-natured human adventurer from Solamnia.\n- The bighearted Ispin loved telling tall tales of his travels to anyone who would listen.\n- Ispin used to adventure with a human Knight of Solamnia named Becklin Uth Viharin and a hill dwarf warrior named Ridomir \"Cudgel\" Ironsmile. These two featured in many of Ispin's stories of fighting sea monsters and goblin raiders.\n- Ispin retired from traveling years ago, becoming a permanent resident of a little-known village in Solamnia called Vogler.",
      "status": "Dead",
      "pageId": "",
      "img": "https://raw.githubusercontent.com/egregiemundi-bot/tangerine-unicorn-9d27ef/main/uploads/npcs/npc-new-npc-2-1784261819221.jpg?v=1784261820343",
      "vibeSong": {
        "title": "My Way - Frank Sinatra",
        "url": "https://open.spotify.com/track/2YkIDPL5lGhRhomCq4S2RO?autoplay_ok=1"
      }
    },
    {
      "id": "new-npc",
      "name": "Lord Bakaris",
      "tag": "Noble · Kalaman",
      "desc": "Lord Bakaris Uth Estide is an arrogant man with a lesser title among the Solamnic nobility. In ages past, his family was known for its wealth and generations of membership in the Knights of Solamnia. While Lord Bakaris retains a considerable amount of wealth, he has lived his entire life on stories of honor and great deeds, none of which are his own. At heart, he’s comically cowardly, full of bluster and inflated words. He has neither the spine to stand up to opposition nor the experience to lead.\n50s, soft around the middle in a way that suggests decades without manual labor, dressed always a little too finely for Vogler's muddy streets.  ",
      "status": "Alive",
      "pageId": "",
      "major": true,
      "location": "Kalaman",
      "vibeSong": {
        "title": "Asshole - Denis Leary",
        "url": "https://open.spotify.com/track/5i0BBU8OZdD7EkYeA5WrSq"
      }
    }
  ],
