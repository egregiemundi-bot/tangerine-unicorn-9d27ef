        "edited": "Today at 7:33 AM",
        "blocks": [
          {
            "type": "heading",
            "icon": "✦",
            "text": "Revival Rules"
          },
          {
            "type": "p",
            "text": "We are using the Matt Mercer resurrection rules for reviving characters."
          },
          {
            "type": "table",
            "head": [
              "Revival Attempt",
              "DC"
            ],
            "rows": [
              [
                "1st",
                "10"
              ],
              [
                "2nd",
                "15"
              ],
              [
                "3rd",
                "20"
              ],
              [
                "4th",
                "25"
              ],
              [
                "5th+",
                "30"
              ]
            ]
          },
          {
            "type": "callout",
            "variant": "dm",
            "title": "DM Note",
            "text": "The true cost of resurrection magic is slowly unraveling the threads between life and death. The characters are not aware of this… yet."
          },
          {
            "type": "heading",
            "icon": "✦",
            "text": "Death Saves"
          },
          {
            "type": "p",
            "text": "We use the standard death save rules with the following clarification."
          },
          {
            "type": "list",
            "items": [
              "Stabilizing a creature does not reset death saves."
            ]
          },
          {
            "type": "callout",
            "variant": "important",
            "title": "Important",
            "text": "A stabilized creature is still at risk until they receive magical healing or a long rest."
          },
          {
            "type": "heading",
            "icon": "✦",
            "text": "Potions"
          },
          {
            "type": "list",
            "items": [
              "Potions are a bonus action to drink unless stated otherwise.",
              "You may pass a potion to another creature within 5 feet as an action.",
              "Identifying a potion takes an action."
            ]
          },
          {
            "type": "callout",
            "variant": "see",
            "title": "See: Potion Identification",
            "text": "Rules for identifying potions and their contents."
          },
          {
            "type": "heading",
            "icon": "✦",
            "text": "Spellcasting"
          },
          {
            "type": "list",
            "items": [
              "Casting a spell using a spell slot expends that slot, whether the spell succeeds or fails.",
              "Components must be on your person unless the spell states otherwise.",
              "Verbal components cannot be spoken if you are gagged or silenced."
            ]
          },
          {
            "type": "callout",
            "variant": "example",
            "title": "Example",
            "text": "If a spell requires a saving throw and the target succeeds, the slot is still expended."
          }
        ],
